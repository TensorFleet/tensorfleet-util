{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "sourceMap": true,

    "rootDir": "./src",
    "outDir": "./dist",
    "declaration": true
  },
  "include": ["src"],
  "exclude": ["dist", "node_modules"]
}